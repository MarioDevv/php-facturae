{
  "name": "php-facturae/php-facturae",
  "description": "Generate, sign and export FacturaE electronic invoices in PHP 8.2+ — fluent API, XAdES-EPES signing, zero dependencies. Genera y firma facturas electrónicas.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "facturae",
    "facturae-php",
    "factura-electronica",
    "electronic-invoice",
    "e-invoicing",
    "e-invoice",
    "spain",
    "spanish",
    "fiscal",
    "xades",
    "xades-epes",
    "xml",
    "xml-signing",
    "aeat",
    "tax",
    "invoice",
    "signing",
    "pkcs12",
    "face",
    "faceb2b",
    "iva",
    "igic",
    "irpf",
    "php-facturae"
  ],
  "homepage": "https://github.com/php-facturae/php-facturae",
  "authors": [
    {
      "name": "Mario Pérez",
      "email": "perezmario.info@gmail.com",
      "homepage": "https://mariodevv.com",
      "role": "Lead Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/php-facturae/php-facturae/issues",
    "source": "https://github.com/php-facturae/php-facturae"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/php-facturae"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-openssl": "*",
    "ext-dom": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "PhpFacturae\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpFacturae\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src --level=8"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
