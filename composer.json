{
  "name": "mariodevv/rex",
  "description": "Spanish business integrations for PHP",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "facturae",
    "factura-electronica",
    "spain",
    "fiscal",
    "xades",
    "xml",
    "aeat"
  ],
  "homepage": "https://github.com/mariodevv/rex",
  "authors": [
    {
      "name": "MarioDevv",
      "email": "perezmario.info@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-openssl": "*",
    "ext-dom": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "MarioDevv\\Rex\\Facturae\\": "src/Facturae/",
      "MarioDevv\\Rex\\Verifactu\\": "src/Verifactu/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MarioDevv\\Rex\\Tests\\Facturae\\": "tests/Facturae/",
      "MarioDevv\\Rex\\Tests\\Verifactu\\": "tests/Verifactu/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src --level=8"
  },
  "minimum-stability": "stable"
}
